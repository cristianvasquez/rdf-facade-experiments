@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.

<urn:Alice> a foaf:Person;
  <http://example.org/likes> <urn:Icecream>;
  foaf:knows <urn:Bob>;
  foaf:name "Alice".

<urn:Bob> a foaf:Person;
  foaf:knows <urn:Alice>;
  foaf:name "Bob".

<urn:Icecream>
  foaf:knows <urn:Alice>.

<urn:Knows>
  foaf:knows <urn:Person>.

<urn:Likes>
  foaf:knows <urn:Person>.

<urn:Team>
  foaf:knows <urn:Person>.

<urn:Team%20Alpha> a <http://example.org/Team>;
  <http://example.org/hasMember>
    <urn:Alice>,
    <urn:Bob>;
  <http://example.org/name> "Team Alpha";
  foaf:knows
    <urn:Alice>,
    <urn:Bob>.
