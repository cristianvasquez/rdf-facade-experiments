@prefix fx: <http://sparql.xyz/facade-x/ns/>.
@prefix md: <http://example.org/markdown#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.

[ a md:Document;
  rdf:_1 [ a md:Section;
      rdf:_1 [ a md:Heading;
          fx:raw "Teams";
          fx:text "Teams";
          rdf:_1 [ a md:Text;
              fx:center "false";
              fx:raw "Teams"
            ]
        ];
      rdf:_2 [ a md:Section;
          rdf:_1 [ a md:Heading;
              fx:raw "Dream team";
              fx:text "Dream team";
              rdf:_1 [ a md:Text;
                  fx:center "false";
                  fx:raw "Dream team"
                ]
            ];
          rdf:_2 [ a md:List;
              fx:ordered "false";
              fx:raw "BobKnowsAlice\nAliceLikesIcecream";
              rdf:_1 [ a md:List_item;
                  fx:raw "BobKnowsAlice";
                  rdf:_1 [ a md:Paragraph;
                      fx:raw "Bob";
                      rdf:_1 [ a md:Text;
                          fx:center "false";
                          fx:raw "Bob"
                        ]
                    ];
                  rdf:_2 [ a md:List;
                      fx:ordered "false";
                      fx:raw "KnowsAlice";
                      rdf:_1 [ a md:List_item;
                          fx:raw "KnowsAlice";
                          rdf:_1 [ a md:Paragraph;
                              fx:raw "Knows";
                              rdf:_1 [ a md:Text;
                                  fx:center "false";
                                  fx:raw "Knows"
                                ]
                            ];
                          rdf:_2 [ a md:List;
                              fx:ordered "false";
                              fx:raw "Alice";
                              rdf:_1 [ a md:List_item;
                                  fx:raw "Alice";
                                  rdf:_1 [ a md:Paragraph;
                                      fx:raw "Alice";
                                      rdf:_1 [ a md:Text;
                                          fx:center "false";
                                          fx:raw "Alice"
                                        ]
                                    ]
                                ]
                            ]
                        ]
                    ]
                ];
              rdf:_2 [ a md:List_item;
                  fx:raw "AliceLikesIcecream";
                  rdf:_1 [ a md:Paragraph;
                      fx:raw "Alice";
                      rdf:_1 [ a md:Text;
                          fx:center "false";
                          fx:raw "Alice"
                        ]
                    ];
                  rdf:_2 [ a md:List;
                      fx:ordered "false";
                      fx:raw "LikesIcecream";
                      rdf:_1 [ a md:List_item;
                          fx:raw "LikesIcecream";
                          rdf:_1 [ a md:Paragraph;
                              fx:raw "Likes";
                              rdf:_1 [ a md:Text;
                                  fx:center "false";
                                  fx:raw "Likes"
                                ]
                            ];
                          rdf:_2 [ a md:List;
                              fx:ordered "false";
                              fx:raw "Icecream";
                              rdf:_1 [ a md:List_item;
                                  fx:raw "Icecream";
                                  rdf:_1 [ a md:Paragraph;
                                      fx:raw "Icecream";
                                      rdf:_1 [ a md:Text;
                                          fx:center "false";
                                          fx:raw "Icecream"
                                        ]
                                    ]
                                ]
                            ]
                        ]
                    ]
                ]
            ]
        ]
    ]
].
