@prefix ex: <http://example.org/>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.

<urn:skill:Git%20Commit%20Assistant> a ex:skill#Skill;
  ex:skill#hasStep
    <urn:step:1>,
    <urn:step:2>,
    <urn:step:3>,
    <urn:step:4>;
  ex:skill#requiresTool
    "Bash",
    "Read";
  ex:skill#triggerPattern
    "Significant code changes are staged",
    "User asks to commit changes",
    "Work on a feature is complete";
  <http://purl.org/dc/terms/description> "Automates git commits with semantic messages";
  <http://purl.org/dc/terms/title> "Git Commit Assistant".

<urn:step:1> a ex:skill#Step;
  ex:skill#action "Run git status and git diff";
  ex:skill#stepNumber "1".

<urn:step:2> a ex:skill#Step;
  ex:skill#action "Analyze changes and draft commit message";
  ex:skill#stepNumber "2".

<urn:step:3> a ex:skill#Step;
  ex:skill#action "Stage files and create commit";
  ex:skill#stepNumber "3".

<urn:step:4> a ex:skill#Step;
  ex:skill#action "Verify commit success";
  ex:skill#stepNumber "4".
