@prefix fx: <http://sparql.xyz/facade-x/ns/>.
@prefix md: <http://example.org/markdown#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.

[ a md:Document;
  rdfs:member [ a md:Section;
      rdfs:member [ a md:Heading;
          fx:raw "Entities";
          fx:text "Entities";
          rdfs:member [ a md:Text;
              fx:center "false";
              fx:raw "Entities"
            ]
        ], [ a md:Section;
          rdfs:member [ a md:Heading;
              fx:raw "Team Alpha";
              fx:text "Team Alpha";
              rdfs:member [ a md:Text;
                  fx:center "false";
                  fx:raw "Team Alpha"
                ]
            ], [ a md:Paragraph;
              fx:raw "*is a* Team";
              rdfs:member [ a md:Emphasis;
                  fx:raw "*is a*";
                  rdfs:member [ a md:Text;
                      fx:center "false";
                      fx:raw "is a"
                    ]
                ], [ a md:Text;
                  fx:center "false";
                  fx:raw " Team"
                ]
            ], [ a md:Paragraph;
              fx:raw "*has member* Bob";
              rdfs:member [ a md:Emphasis;
                  fx:raw "*has member*";
                  rdfs:member [ a md:Text;
                      fx:center "false";
                      fx:raw "has member"
                    ]
                ], [ a md:Text;
                  fx:center "false";
                  fx:raw " Bob"
                ]
            ], [ a md:Paragraph;
              fx:raw "*has member* Alice";
              rdfs:member [ a md:Emphasis;
                  fx:raw "*has member*";
                  rdfs:member [ a md:Text;
                      fx:center "false";
                      fx:raw "has member"
                    ]
                ], [ a md:Text;
                  fx:center "false";
                  fx:raw " Alice"
                ]
            ]
        ], [ a md:Section;
          rdfs:member [ a md:Heading;
              fx:raw "Bob";
              fx:text "Bob";
              rdfs:member [ a md:Text;
                  fx:center "false";
                  fx:raw "Bob"
                ]
            ], [ a md:Paragraph;
              fx:raw "*is a* Person";
              rdfs:member [ a md:Emphasis;
                  fx:raw "*is a*";
                  rdfs:member [ a md:Text;
                      fx:center "false";
                      fx:raw "is a"
                    ]
                ], [ a md:Text;
                  fx:center "false";
                  fx:raw " Person"
                ]
            ], [ a md:Paragraph;
              fx:raw "*knows* Alice";
              rdfs:member [ a md:Emphasis;
                  fx:raw "*knows*";
                  rdfs:member [ a md:Text;
                      fx:center "false";
                      fx:raw "knows"
                    ]
                ], [ a md:Text;
                  fx:center "false";
                  fx:raw " Alice"
                ]
            ]
        ], [ a md:Section;
          rdfs:member [ a md:Heading;
              fx:raw "Alice";
              fx:text "Alice";
              rdfs:member [ a md:Text;
                  fx:center "false";
                  fx:raw "Alice"
                ]
            ], [ a md:Paragraph;
              fx:raw "*is a* Person";
              rdfs:member [ a md:Emphasis;
                  fx:raw "*is a*";
                  rdfs:member [ a md:Text;
                      fx:center "false";
                      fx:raw "is a"
                    ]
                ], [ a md:Text;
                  fx:center "false";
                  fx:raw " Person"
                ]
            ], [ a md:Paragraph;
              fx:raw "*likes* Icecream";
              rdfs:member [ a md:Emphasis;
                  fx:raw "*likes*";
                  rdfs:member [ a md:Text;
                      fx:center "false";
                      fx:raw "likes"
                    ]
                ], [ a md:Text;
                  fx:center "false";
                  fx:raw " Icecream"
                ]
            ]
        ]
    ]
].
