@prefix fx: <http://sparql.xyz/facade-x/ns/>.
@prefix md: <http://example.org/markdown#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.

[ a md:Document;
  rdfs:member [ a md:Section;
      rdfs:member [ a md:Heading;
          fx:raw "Teams";
          fx:text "Teams";
          rdfs:member [ a md:Text;
              fx:center "false";
              fx:raw "Teams"
            ]
        ], [ a md:Section;
          rdfs:member [ a md:Heading;
              fx:raw "Team Alpha";
              fx:text "Team Alpha";
              rdfs:member [ a md:Text;
                  fx:center "false";
                  fx:raw "Team Alpha"
                ]
            ], [ a md:List;
              fx:ordered "false";
              fx:raw "BobKnowsAlice\nAliceLikesIcecream";
              rdfs:member [ a md:List_item;
                  fx:raw "BobKnowsAlice";
                  rdfs:member [ a md:Paragraph;
                      fx:raw "Bob";
                      rdfs:member [ a md:Text;
                          fx:center "false";
                          fx:raw "Bob"
                        ]
                    ], [ a md:List;
                      fx:ordered "false";
                      fx:raw "KnowsAlice";
                      rdfs:member [ a md:List_item;
                          fx:raw "KnowsAlice";
                          rdfs:member [ a md:Paragraph;
                              fx:raw "Knows";
                              rdfs:member [ a md:Text;
                                  fx:center "false";
                                  fx:raw "Knows"
                                ]
                            ], [ a md:List;
                              fx:ordered "false";
                              fx:raw "Alice";
                              rdfs:member [ a md:List_item;
                                  fx:raw "Alice";
                                  rdfs:member [ a md:Paragraph;
                                      fx:raw "Alice";
                                      rdfs:member [ a md:Text;
                                          fx:center "false";
                                          fx:raw "Alice"
                                        ]
                                    ]
                                ]
                            ]
                        ]
                    ]
                ], [ a md:List_item;
                  fx:raw "AliceLikesIcecream";
                  rdfs:member [ a md:Paragraph;
                      fx:raw "Alice";
                      rdfs:member [ a md:Text;
                          fx:center "false";
                          fx:raw "Alice"
                        ]
                    ], [ a md:List;
                      fx:ordered "false";
                      fx:raw "LikesIcecream";
                      rdfs:member [ a md:List_item;
                          fx:raw "LikesIcecream";
                          rdfs:member [ a md:Paragraph;
                              fx:raw "Likes";
                              rdfs:member [ a md:Text;
                                  fx:center "false";
                                  fx:raw "Likes"
                                ]
                            ], [ a md:List;
                              fx:ordered "false";
                              fx:raw "Icecream";
                              rdfs:member [ a md:List_item;
                                  fx:raw "Icecream";
                                  rdfs:member [ a md:Paragraph;
                                      fx:raw "Icecream";
                                      rdfs:member [ a md:Text;
                                          fx:center "false";
                                          fx:raw "Icecream"
                                        ]
                                    ]
                                ]
                            ]
                        ]
                    ]
                ]
            ]
        ]
    ]
].
