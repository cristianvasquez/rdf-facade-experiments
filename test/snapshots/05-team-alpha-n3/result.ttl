@prefix ex: <http://example.org/>.
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.

[ a ex:Team;
  ex:hasMember [ a foaf:Person;
      ex:relationship "knows";
      ex:target " Alice";
      foaf:name "Bob"
    ], [ a foaf:Person;
      ex:relationship "likes";
      ex:target " Icecream";
      foaf:name "Alice"
    ];
  ex:name "Team Alpha"
].
