@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix : <http://example.org/> .

<urn:Dream_Team> a :Team ;
  :name "Dream Team" ;
  :hasMember <urn:Bob> ;
  :hasMember <urn:Alice> .

<urn:Bob> a foaf:Person ;
  foaf:name "Bob" ;
  foaf:knows <urn:Alice> .

<urn:Alice> a foaf:Person ;
  foaf:name "Alice" ;
  :likes <urn:Icecream> .
